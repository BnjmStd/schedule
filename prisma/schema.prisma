// ================================================================
// 🏗️  PRISMA SCHEMA — School Timetable SaaS
// Production-grade | Multi-tenant | PostgreSQL
// Refactored: 2026-03-15
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================================================
// 🔤 ENUMS
// ================================================================

enum UserRole {
  OWNER       // School owner — full access, manages subscription
  ADMIN       // Delegated admin — full access except billing
  STAFF       // Operational access (limited)
  VIEWER      // Read-only
  SUPER_ADMIN // Global panel — not tied to a specific school
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum AcademicLevel {
  BASIC  // 1°–8° Básico
  MIDDLE // 1°–4° Medio
}

enum AuditAction {
  USER_CREATED
  USER_DELETED
  ROLE_CHANGED
  OWNER_TRANSFERRED
  SUBSCRIPTION_CHANGED
  SCHEDULE_GENERATED
  SCHEDULE_PUBLISHED
}

enum GenerationStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  INCOMPLETE
}

// ================================================================
// 🏢 ORGANIZATION — Multi-school tenant grouping
// Allows a single entity to own multiple schools.
// Schools can exist independently (organizationId is optional).
// ================================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schools School[]

  @@map("organizations")
}

// ================================================================
// 👤 USER & AUTH
// ================================================================

model User {
  id            String    @id @default(cuid())
  schoolId      String?   // Null for SUPER_ADMIN (global panel user)
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  role          UserRole  @default(STAFF)
  deletedAt     DateTime? // Soft delete — user data preserved for audit trail

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school         School?                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessions       Session[]
  generationJobs ScheduleGenerationJob[]

  @@index([schoolId])
  @@index([deletedAt]) // Fast filter for active users
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ================================================================
// 🏫 SCHOOL — The primary billing and multi-tenant unit
// Each school has exactly one subscription.
// All resources are scoped by schoolId.
// ================================================================

model School {
  id             String  @id @default(cuid())
  organizationId String? // Optional: organization-owned schools

  name    String
  address String
  phone   String?
  email   String?

  // Comma-separated active academic levels: "BASIC", "MIDDLE", or "BASIC,MIDDLE"
  // Parsed by src/lib/utils/academic-levels.ts
  activeAcademicLevels String @default("BASIC,MIDDLE")

  // ⚠️  DEPRECATED — Kept only for backwards-compatibility with existing data.
  //     Use ScheduleLevelConfig for all new schedule configuration.
  scheduleStartTime String  @default("08:00")
  scheduleEndTime   String  @default("17:00")
  blockDuration     Int     @default(45)
  breakDuration     Int     @default(15)
  lunchBreakEnabled Boolean @default(true)
  lunchBreakConfig  Json    @default("{}")
  lunchBreakStart   String  @default("13:00")
  lunchBreakEnd     String  @default("14:00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization        Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  users               User[]
  teachers            Teacher[]
  subjects            Subject[]
  courses             Course[]
  schedules           Schedule[]
  levelConfigs        ScheduleLevelConfig[]
  teacherWorkloads    TeacherWorkloadLimit[]
  subjectRequirements CourseSubjectRequirement[]
  subscription        SchoolSubscription?
  billingEvents       BillingEvent[]
  auditLogs           AuditLog[]
  generationJobs      ScheduleGenerationJob[]

  @@index([organizationId])
  @@map("schools")
}

// ================================================================
// ⚙️  SCHEDULE LEVEL CONFIG — Per academic-level timetable settings
// Replaces the deprecated per-school flat fields.
// Each school can have one config per academic level (BASIC / MIDDLE).
// ================================================================

model ScheduleLevelConfig {
  id            String        @id @default(cuid())
  schoolId      String
  academicLevel AcademicLevel

  // Stored as native PostgreSQL TIME (no timezone).
  // Application code: use timeToDate() / dateToTime() helpers.
  startTime     DateTime @db.Time @default(dbgenerated("'08:00:00'::time"))
  endTime       DateTime @db.Time @default(dbgenerated("'17:00:00'::time"))
  blockDuration Int      @default(45) // Minutes — must be a multiple of 15

  // JSON array: [{ "afterBlock": 2, "duration": 15, "name": "Recreo" }, ...]
  breaks Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School                       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  history ScheduleLevelConfigHistory[]

  @@unique([schoolId, academicLevel])
  @@index([schoolId])
  @@map("schedule_level_configs")
}

// ================================================================
// 📜 SCHEDULE LEVEL CONFIG HISTORY — Immutable change log
// ================================================================

model ScheduleLevelConfigHistory {
  id            String        @id @default(cuid())
  configId      String
  schoolId      String
  academicLevel AcademicLevel

  startTime     DateTime @db.Time
  endTime       DateTime @db.Time
  blockDuration Int
  breaks        Json

  changedBy    String? // userId
  changeReason String?
  createdAt    DateTime @default(now())

  config ScheduleLevelConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([schoolId])
  @@index([createdAt])
  @@index([schoolId, academicLevel, createdAt])
  @@map("schedule_level_config_history")
}

// ================================================================
// 👨‍🏫 TEACHER
// ================================================================

model Teacher {
  id             String    @id @default(cuid())
  schoolId       String
  firstName      String
  lastName       String
  email          String
  phone          String?
  specialization String?
  deletedAt      DateTime? // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school                  School                         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  availability            TeacherAvailability[]
  availabilityExceptions  TeacherAvailabilityException[]
  workloadLimits          TeacherWorkloadLimit[]
  teacherSubjects         TeacherSubject[]
  scheduleBlocks          ScheduleBlock[]
  preferredInRequirements CourseSubjectRequirement[]     @relation("PreferredTeacher")

  @@index([schoolId])
  @@index([schoolId, deletedAt]) // Efficient soft-delete filtering
  @@map("teachers")
}

// ================================================================
// 📅 TEACHER AVAILABILITY — Structural weekly availability
// schoolId is denormalized here for direct multi-tenant queries
// without requiring a join through Teacher.
// ================================================================

model TeacherAvailability {
  id           String    @id @default(cuid())
  teacherId    String
  schoolId     String    // Denormalized for multi-tenant isolation
  academicYear Int
  dayOfWeek    DayOfWeek
  startTime    DateTime  @db.Time
  endTime      DateTime  @db.Time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, academicYear, dayOfWeek, startTime, endTime])
  @@index([teacherId])
  @@index([teacherId, academicYear])
  @@index([schoolId, academicYear])
  @@map("teacher_availability")
}

// ================================================================
// 🚫 TEACHER AVAILABILITY EXCEPTIONS — Specific date overrides
// Models: sick leave, holidays, single-day blocks, ad-hoc availability.
// ================================================================

model TeacherAvailabilityException {
  id          String    @id @default(cuid())
  teacherId   String
  date        DateTime
  startTime   DateTime? @db.Time // null = entire day
  endTime     DateTime? @db.Time // null = entire day
  isAvailable Boolean   @default(false) // false = blocked, true = extra availability
  reason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([teacherId, date])
  @@index([date])
  @@map("teacher_availability_exceptions")
}

// ================================================================
// 📊 TEACHER WORKLOAD LIMIT — Per-year teaching load cap
// ================================================================

model TeacherWorkloadLimit {
  id               String    @id @default(cuid())
  teacherId        String
  schoolId         String
  academicYear     Int
  maxBlocksPerDay  Int       @default(6)
  maxBlocksPerWeek Int       @default(30)

  // Soft constraints: preferred working window for the solver
  preferredStartTime DateTime? @db.Time
  preferredEndTime   DateTime? @db.Time
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([teacherId, academicYear])
  @@index([schoolId, academicYear])
  @@map("teacher_workload_limits")
}

// ================================================================
// 📚 SUBJECT
// ================================================================

model Subject {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  color       String?
  deletedAt   DateTime? // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school              School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherSubjects     TeacherSubject[]
  scheduleBlocks      ScheduleBlock[]
  subjectRequirements CourseSubjectRequirement[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([schoolId, deletedAt])
  @@map("subjects")
}

// ================================================================
// 🔗 TEACHER-SUBJECT (Many-to-Many)
// schoolId denormalized to enforce cross-school isolation at query level.
// ================================================================

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  schoolId  String   // Denormalized for multi-tenant isolation

  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@index([teacherId])
  @@index([subjectId])
  @@index([schoolId])
  @@map("teacher_subjects")
}

// ================================================================
// 🎓 COURSE
// ================================================================

model Course {
  id            String        @id @default(cuid())
  schoolId      String
  name          String        // e.g., "1° Básico A"
  grade         String        // e.g., "1", "2"
  section       String        // e.g., "A", "B"
  academicLevel AcademicLevel
  academicYear  Int
  studentCount  Int?
  deletedAt     DateTime?     // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school              School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schedules           Schedule[]
  subjectRequirements CourseSubjectRequirement[]

  @@index([schoolId])
  @@index([academicYear])
  @@index([academicLevel])
  @@index([schoolId, academicYear])
  @@index([schoolId, academicYear, academicLevel]) // Hot query path for the generator
  @@index([schoolId, deletedAt])
  @@map("courses")
}

// ================================================================
// 📋 COURSE SUBJECT REQUIREMENT
// Source of truth for the constraint solver:
// how many weekly blocks each subject requires per course.
// ================================================================

model CourseSubjectRequirement {
  id           String @id @default(cuid())
  schoolId     String
  courseId     String
  subjectId    String
  academicYear Int

  blocksPerWeek          Int
  preferredTeacherId     String?
  maxConsecutiveBlocks   Int     @default(2)
  preferredDays          Json    @default("[]") // Array of DayOfWeek string values
  avoidAfterLunch        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  preferredTeacher Teacher? @relation("PreferredTeacher", fields: [preferredTeacherId], references: [id], onDelete: SetNull)

  @@unique([courseId, subjectId, academicYear])
  @@index([schoolId])
  @@index([courseId, academicYear])
  @@index([subjectId, academicYear])
  @@map("course_subject_requirements")
}

// ================================================================
// 🗓️ SCHEDULE
// Supports versioning and draft/published lifecycle.
// version + courseId (via @@index) allows multiple draft versions.
// ================================================================

model Schedule {
  id           String    @id @default(cuid())
  schoolId     String
  courseId     String
  name         String
  academicYear Int
  semester     Int
  startDate    DateTime
  endDate      DateTime

  isActive     Boolean   @default(true)
  isLocked     Boolean   @default(false) // True = no further edits allowed
  publishedAt  DateTime?                 // Null = draft
  version      Int       @default(1)     // Incremented on each publish

  configSnapshot Json?    // Snapshot of ScheduleLevelConfig at creation time
  isDeprecated   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school            School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course            Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  blocks            ScheduleBlock[]
  generationResults ScheduleGenerationResult[]

  @@index([schoolId])
  @@index([courseId])
  @@index([academicYear])
  @@index([isActive])
  @@index([isDeprecated])
  @@index([schoolId, academicYear, isActive])
  @@map("schedules")
}

// ================================================================
// 🧱 SCHEDULE BLOCK
//
// HARD CONSTRAINTS (enforced at DB level):
//   1. A course cannot have two blocks in the same slot:
//      @@unique([scheduleId, dayOfWeek, blockNumber])
//   2. A teacher cannot be double-booked in the same year:
//      @@unique([teacherId, dayOfWeek, startTime, academicYear])
//
// schoolId is denormalized for fast multi-tenant queries without JOIN.
// academicYear is denormalized to enable the teacher uniqueness constraint.
// ================================================================

model ScheduleBlock {
  id          String    @id @default(cuid())
  scheduleId  String
  schoolId    String    // Denormalized for multi-tenant isolation
  subjectId   String
  teacherId   String
  dayOfWeek   DayOfWeek
  blockNumber Int
  startTime   DateTime  @db.Time
  endTime     DateTime  @db.Time
  duration    Int       // Minutes
  academicYear Int      @default(2026) // Denormalized — backfill from schedule.academicYear
  classroom   String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  subject  Subject  @relation(fields: [subjectId], references: [id])
  teacher  Teacher  @relation(fields: [teacherId], references: [id])

  // HARD CONSTRAINT: one subject per slot per schedule
  @@unique([scheduleId, dayOfWeek, blockNumber])
  // HARD CONSTRAINT: teacher cannot be in two places at the same time
  @@unique([teacherId, dayOfWeek, startTime, academicYear])

  @@index([scheduleId])
  @@index([teacherId])
  @@index([teacherId, academicYear])
  @@index([schoolId, academicYear])
  @@index([dayOfWeek, startTime])
  @@index([academicYear])
  @@map("schedule_blocks")
}

// ================================================================
// 🤖 SCHEDULE GENERATION JOB
// Tracks every automatic timetable generation run.
// Enables async processing, progress monitoring, re-runs, and auditing.
// ================================================================

model ScheduleGenerationJob {
  id              String           @id @default(cuid())
  schoolId        String
  academicYear    Int
  semester        Int
  status          GenerationStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  score           Float?           // Objective score from the solver (higher = better)
  iterations      Int?             // Solver iterations completed
  logs            Json             @default("[]") // Structured run log entries
  configSnapshot  Json             @default("{}") // Copy of relevant config at launch time
  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User?                      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  results   ScheduleGenerationResult[]

  @@index([schoolId])
  @@index([status])
  @@index([schoolId, academicYear])
  @@index([schoolId, status])
  @@map("schedule_generation_jobs")
}

// ================================================================
// 📊 SCHEDULE GENERATION RESULT
// Links a generation job to the schedules it produced,
// along with per-schedule quality metrics and constraint violations.
// ================================================================

model ScheduleGenerationResult {
  id                   String   @id @default(cuid())
  jobId                String
  scheduleId           String
  score                Float?
  constraintViolations Json     @default("[]") // Array of { rule, severity, description }

  createdAt DateTime @default(now())

  job      ScheduleGenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  schedule Schedule              @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([scheduleId])
  @@map("schedule_generation_results")
}

// ================================================================
// 💳 BILLING & SUBSCRIPTIONS
//
// ARCHITECTURE: Subscription is per-School, not per-user.
// The School is the billing customer.
// Ready to scale to Organization → Schools → Subscription.
// ================================================================

model SchoolSubscription {
  id       String @id @default(cuid())
  schoolId String @unique

  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  currentPeriodStart   DateTime  @default(now())
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  canceledAt           DateTime?
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  metadata Json @default("{}") // Extensible flags: grandfatheredPro, trialExtended, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  history SubscriptionHistory[]

  @@index([status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
  @@map("school_subscriptions")
}

model SubscriptionHistory {
  id             String @id @default(cuid())
  subscriptionId String

  oldPlan SubscriptionPlan
  newPlan SubscriptionPlan
  oldStatus SubscriptionStatus
  newStatus SubscriptionStatus

  // Origin: "school_request" | "stripe_webhook" | "admin" | "trial_expired" | "cron_expiry"
  reason    String?
  changedAt DateTime @default(now())

  subscription SchoolSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([changedAt])
  @@index([subscriptionId, changedAt])
  @@map("subscription_history")
}

// ================================================================
// 📨 BILLING EVENT — Stripe webhook idempotency log
// stripeEventId @unique guarantees at-most-once processing.
// ================================================================

model BillingEvent {
  id            String    @id @default(cuid())
  schoolId      String?
  stripeEventId String    @unique
  type          String    // e.g., "invoice.payment_succeeded"
  payload       Json      // Full Stripe Event object

  processed    Boolean   @default(false)
  processedAt  DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([processed, createdAt])
  @@index([schoolId])
  @@map("billing_events")
}

// ================================================================
// 📋 AUDIT LOG — Immutable history of sensitive actions
// action uses a strict enum to prevent typo-driven gaps in the log.
// ================================================================

model AuditLog {
  id        String      @id @default(cuid())
  schoolId  String?     // Null for SUPER_ADMIN global actions
  actorId   String      // userId of who performed the action
  actorRole String      // Role at the time of the action

  action   AuditAction
  entity   String      // e.g., "User", "School", "SchoolSubscription"
  entityId String
  metadata Json        @default("{}") // { oldRole, newRole, targetUserId, ... }

  createdAt DateTime @default(now())

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([actorId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([schoolId, createdAt])
  @@map("audit_logs")
}
